{
  "name": "zar3a-backend",
  "version": "1.0.0",
  "description": "Zar3a Agricultural Platform — Node.js + MySQL Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma db push",
    "create-admin": "node scripts/create-admin.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "google-auth-library": "^9.10.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.10.1",
    "sequelize": "^6.37.8",
    "stripe": "^22.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0"
  }
}
