# ════════════════════════════════════════════════
#   Zar3a Backend — Environment Variables
# ════════════════════════════════════════════════

# ── MySQL connection ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zar3a_db
DB_USER=root
DB_PASS=
DATABASE_URL="mysql://root:@localhost:3306/zar3a_db"

# ── Server ────────────────────────────────────────
PORT=5002
NODE_ENV=development

# ── CORS: your frontend URL ───────────────────────
CLIENT_URL=http://localhost:5173

# ── JWT secrets ───────────────────────────────────
JWT_ACCESS_SECRET=zar3a-access-secret-change-me
JWT_REFRESH_SECRET=zar3a-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth (optional — leave blank to skip) ─
GOOGLE_CLIENT_ID=

# ── File uploads ──────────────────────────────────
CV_UPLOAD_DIR=uploads/cv
